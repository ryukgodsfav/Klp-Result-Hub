.sport-icon-item { cursor: default; }
.sport-emoji { font-size: 2.5rem; margin-bottom: 8px; }
.sport-name { font-size: 13px; color: rgba(255,255,255,0.8); font-weight: 500; }

/* ── Hiring Partners Slider ───────────────────────── */
.partners-slider-wrapper {
    overflow: hidden; border-radius: 12px;
    position: relative; mask-image: linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%);
}
.partners-slider {
    display: flex; gap: 20px;
    animation: scrollSlider 40s linear infinite;
    width: max-content;
}
.partners-slider:hover { animation-play-state: paused; }
@keyframes scrollSlider {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
}
.partner-slide { flex-shrink: 0; width: 200px; }
.partner-card {
    background: white; border-radius: 12px; padding: 24px 16px;
    border: 1px solid #e8eaed;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    text-align: center; height: 140px;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    transition: box-shadow 0.2s;
}
.partner-card:hover { box-shadow: 0 6px 20px rgba(26,35,126,0.12); }
.partner-logo-placeholder {
    width: 56px; height: 56px; border-radius: 12px;
    background: linear-gradient(135deg, var(--klp-navy), var(--klp-blue));
    color: white; font-weight: 800; font-size: 18px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 10px;
}
.partner-name { font-weight: 700; font-size: 13px; color: #1a1a2e; line-height: 1.2; margin-bottom: 4px; }
.partner-sector { font-size: 11px; color: #6b7280; }

/* ── UBTER Section ────────────────────────────────── */
.bg-primary-dark { background: linear-gradient(135deg, #0a0f3d 0%, var(--klp-navy) 100%); }
.ubter-card {
    background: rgba(255,255,255,0.07); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.15); border-radius: 16px;
    padding: 28px; height: 100%;
}
.ubter-card-icon {
    font-size: 2rem; color: var(--klp-gold);
    margin-bottom: 16px; display: block;
}
.text-white-75 { color: rgba(255,255,255,0.75) !important; }
.text-white-50 { color: rgba(255,255,255,0.5) !important; }

/* ── Result CTA ───────────────────────────────────── */
.result-cta-section {
    background: linear-gradient(135deg, #c62828 0%, #b71c1c 100%);
}
.result-cta-box { max-width: 700px; margin: 0 auto; }
.result-cta-icon {
    font-size: 4rem; color: var(--klp-gold);
    animation: pulseGlow 2s ease-in-out infinite alternate;
}
@keyframes pulseGlow {
    from { filter: drop-shadow(0 0 10px rgba(255,193,7,0.3)); }
    to   { filter: drop-shadow(0 0 30px rgba(255,193,7,0.8)); }
}

