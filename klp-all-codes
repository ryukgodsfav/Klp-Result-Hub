{% block extra_js %}
<script>
/* Dynamically add/remove subject rows */

// Template HTML for a new theory row
function makeRow(type, num) {
    const gradeOpts = `<option value="">—</option><option>O</option><option>A+</option><option>A</option><option>B+</option><option>B</option><option>C</option><option>D</option><option>F</option>`;
    const maxDefault = type === 'Theory' ? 100 : 50;
    const codePlaceholder = type === 'Theory' ? 'e.g. ME-101' : 'e.g. ME-101P';
    return `<tr class="subject-row">
        <td class="row-num text-center text-muted">${num}</td>
        <td><input type="text" class="form-control form-control-sm" name="subject_code" placeholder="${codePlaceholder}"></td>
        <td><input type="text" class="form-control form-control-sm" name="subject_name" placeholder="Subject Name"></td>
        <td><input type="number" class="form-control form-control-sm" name="max_marks" value="${maxDefault}" min="0" max="1000"></td>
        <td><input type="number" class="form-control form-control-sm" name="marks_obtained" value="" min="0" max="1000" placeholder="0"></td>
        <td><select class="form-select form-select-sm" name="grade">${gradeOpts}</select></td>
        <td><select class="form-select form-select-sm" name="result"><option value="">—</option><option>PASS</option><option>FAIL</option></select></td>
        <td class="text-center"><input type="hidden" name="subject_type" value="${type}"><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(this)"><i class="bi bi-trash"></i></button></td>
    </tr>`;
}

// Add a new row to the correct table
function addRow(type) {
    const tbody = document.getElementById(type === 'theory' ? 'theoryBody' : 'practicalBody');
    const num = tbody.querySelectorAll('tr.subject-row').length + 1;
    const typeCap = type === 'theory' ? 'Theory' : 'Practical';
    tbody.insertAdjacentHTML('beforeend', makeRow(typeCap, num));
    // Renumber
    renumber(tbody);
}

// Remove a row and renumber
function removeRow(btn) {
    const row = btn.closest('tr');
    const tbody = row.closest('tbody');
    row.remove();
    renumber(tbody);
}

// Renumber all rows in a tbody
function renumber(tbody) {
    tbody.querySelectorAll('tr.subject-row').forEach((row, i) => {
        const numCell = row.querySelector('.row-num');
        if (numCell) numCell.textContent = i + 1;
    });
}
</script>
{% endblock %}

