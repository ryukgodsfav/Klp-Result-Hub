/* ── Root Variables ───────────────────────────────── */
:root {
    --klp-navy:   #1a237e;
    --klp-blue:   #283593;
    --klp-gold:   #ffc107;
    --klp-dark:   #0d1117;
    --klp-light:  #f4f6fb;
    --klp-green:  #1b5e20;
    --klp-red:    #c62828;
    --font-main:  'Poppins', sans-serif;
}

/* ── Global Base ──────────────────────────────────── */
* { box-sizing: border-box; }
body {
    font-family: var(--font-main);
    background: #f8f9fc;
    color: #2c2c2c;
}
html { scroll-behavior: smooth; }

/* ── Navigation ───────────────────────────────────── */
#mainNav {
    background: linear-gradient(135deg, var(--klp-navy) 0%, var(--klp-blue) 100%);
    box-shadow: 0 2px 20px rgba(0,0,0,0.3);
    padding: 8px 0;
}
.nav-logo-circle {
    width: 44px; height: 44px;
    background: var(--klp-gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: 15px; color: var(--klp-navy);
    border: 2px solid rgba(255,255,255,0.3);
    flex-shrink: 0;
}
.nav-college-name { font-size: 15px; font-weight: 700; line-height: 1.2; color: #fff; }
.nav-college-sub  { font-size: 10px; color: rgba(255,255,255,0.7); line-height: 1; }
.navbar-nav .nav-link {
    color: rgba(255,255,255,0.85) !important;
    font-weight: 500; font-size: 14px; padding: 6px 12px;
    border-radius: 6px; transition: all 0.2s;
}
.navbar-nav .nav-link:hover {
    color: #fff !important; background: rgba(255,255,255,0.12);
}

/* ── Hero Section ─────────────────────────────────── */
.klp-hero {
    background: linear-gradient(135deg, #0a0f3d 0%, #1a237e 40%, #1565c0 100%);
    position: relative; overflow: hidden; min-height: 85vh;
    display: flex; align-items: center;
}
.klp-hero::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
.hero-overlay {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, rgba(255,193,7,0.08) 0%, transparent 70%);
}
.min-vh-75 { min-height: 75vh; }
.hero-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900; letter-spacing: -1px; line-height: 1.1;
    text-shadow: 2px 4px 12px rgba(0,0,0,0.4);
}
.hero-subtitle {
    font-size: clamp(1.3rem, 3vw, 2rem);
    font-weight: 700; letter-spacing: 2px; margin: 0;
}
.hero-tagline {
    font-size: 1rem; color: rgba(255,255,255,0.8); line-height: 1.7;
}
.hero-estd { font-size: 12px; letter-spacing: 1px; }

/* Navbar logo image */
.nav-logo-img {
    height: 42px; width: 42px;
    object-fit: contain;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
    border-radius: 4px;
}

/* Founder Frame — real photo */
.founder-frame {
    width: 190px; height: 210px;
    border: 4px solid var(--klp-gold);
    border-radius: 50%;
    overflow: hidden;
    background: rgba(255,255,255,0.05);
    box-shadow: 0 0 0 6px rgba(255,193,7,0.25), 0 8px 32px rgba(0,0,0,0.4);
    display: flex; align-items: center; justify-content: center;
}
.founder-photo {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center top;
    display: block;
}

/* KLP College Logo (hero right side) */
.klp-logo-img-wrap {
    width: 200px; height: 220px;
    display: flex; align-items: center; justify-content: center;
    filter: drop-shadow(0 8px 24px rgba(0,0,0,0.5));
}
.klp-logo-img {
    width: 100%; height: 100%;
    object-fit: contain;
    animation: logoFloat 4s ease-in-out infinite;
}
@keyframes logoFloat {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
}

/* Hero scroll down */
.hero-scroll-down {
    position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
    animation: bounce 2s infinite;
}
.scroll-arrow { font-size: 1.6rem; }
@keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(-10px); }
}

/* ── Stats Bar ────────────────────────────────────── */
.stats-bar {
    background: var(--klp-navy);
    color: white;
}
.stat-item {
    display: flex; flex-direction: column; align-items: center;
    padding: 8px 0;
}
.stat-num {
    font-size: 2rem; font-weight: 800; color: var(--klp-gold); line-height: 1;
}
.stat-label { font-size: 12px; color: rgba(255,255,255,0.7); margin-top: 2px; }

/* ── Section Header ───────────────────────────────── */
.section-badge {
    display: inline-block; background: rgba(26,35,126,0.1);
    color: var(--klp-navy); border: 1px solid rgba(26,35,126,0.2);
