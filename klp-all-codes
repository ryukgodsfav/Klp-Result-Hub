.sports-icon { font-size: 2.5rem; }
.sports-name { font-size: 1.2rem; font-weight: 700; }
.sports-desc { color: rgba(255,255,255,0.8); font-size: 14px; line-height: 1.7; margin-bottom: 16px; }
